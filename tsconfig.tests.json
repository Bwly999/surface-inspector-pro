{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".tmp-tests-run"
  },
  "include": [
    "tests/**/*.spec.ts",
    "utils/dataUtils.ts",
    "utils/rangeUtils.ts",
    "utils/processUtils.ts",
    "utils/mathUtils.ts",
    "types.ts"
  ]
}
